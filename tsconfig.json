{
  "compilerOptions": {
    "target":        "ES2020",
    "module":        "commonjs",
    "lib":           ["ES2020"],
    "strict":        false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck":  true,
    "outDir":        "./dist",
    "rootDir":       "./"
  },
  "include": ["src/**/*.ts", "*.ts"],
  "exclude": ["node_modules", "dist"]
}
