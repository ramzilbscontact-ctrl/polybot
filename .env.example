# ════════════════════════════════════════════════════════════
#  POLYBOT — Environment Variables Template
#  Copy this file to .env and fill in your values
#  > cp .env.example .env
# ════════════════════════════════════════════════════════════

# ── Wallet (Polygon Mainnet) ──────────────────────────────────
PRIVATE_KEY=          # 64-char hex Ethereum private key (no 0x prefix)
POLY_ADDRESS=         # Your wallet address (0x...)

# ── RPC Provider ─────────────────────────────────────────────
ALCHEMY_URL=          # https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Polymarket CLOB API (generated by setup.ts) ──────────────
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# ── Strategy Parameters (optional — defaults shown) ──────────
YES_MIN=0.88              # Minimum YES price (bestAsk)
YES_MAX=0.94              # Maximum YES price (bestAsk)
STAKE_USDC=0.80           # Fixed stake per trade (USDC.e)
EXPIRY_MAX_H=48           # Max expiry window (hours)
CRYPTO_BUFFER=60          # Real price buffer vs bet threshold ($)
MAX_TRADES=3              # Max simultaneous open trades
MAX_LOSS=2.00             # Global stop-loss (USDC.e)

# ── Runtime ───────────────────────────────────────────────────
SCAN_INTERVAL_S=60        # Scan interval (seconds)
LOG_LEVEL=info            # Winston log level: debug | info | warn | error
DRY_RUN=false             # true = simulate only, no real orders
